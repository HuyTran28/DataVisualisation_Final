expression batdongsan_real_estate_cleaned =
		let
		    Source = Csv.Document(File.Contents(DatasetFolderPath & "\batdongsan_real_estate_cleaned.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
		    #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
		    #"Trimmed Boolean Columns" = Table.TransformColumns(#"Promoted Headers", {
		        {"has_elevator", each Text.Trim(Text.From(_))},
		        {"near_park", each Text.Trim(Text.From(_))},
		        {"is_frontage_road", each Text.Trim(Text.From(_))}
		    }),
		    #"Converted Boolean Text" = Table.TransformColumns(#"Trimmed Boolean Columns", {
		        {"has_elevator", each if Text.Lower(_) = "true" then true else if Text.Lower(_) = "false" then false else null},
		        {"near_park", each if Text.Lower(_) = "true" then true else if Text.Lower(_) = "false" then false else null},
		        {"is_frontage_road", each if Text.Lower(_) = "true" then true else if Text.Lower(_) = "false" then false else null}
		    }),
		    #"Changed Type" = Table.TransformColumnTypes(#"Converted Boolean Text", {
		        {"product_id", Int64.Type},
		        {"title", type text},
		        {"url", type text},
		        {"description", type text},
		        {"price_total", Int64.Type},
		        {"price_per_m2", type number},
		        {"area", type number},
		        {"frontage", type number},
		        {"road_width", type number},
		        {"bedrooms", Int64.Type},
		        {"bathrooms", Int64.Type},
		        {"floors", Int64.Type},
		        {"price_trend_1y", type number},
		        {"city", type text},
		        {"district", type text},
		        {"ward", type text},
		        {"street", type text},
		        {"full_address", type text},
		        {"direction", type text},
		        {"interior", type text},
		        {"legal_status", type text},
		        {"post_rank", type text},
		        {"has_elevator", type logical},
		        {"near_park", type logical},
		        {"is_frontage_road", type logical},
		        {"posted_date", type datetime},
		        {"expiry_date", type datetime}
		    })
		in
		    #"Changed Type"
	lineageTag: 1d5f6a1d-7f03-4565-9bb1-e2ffff6223e0

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
