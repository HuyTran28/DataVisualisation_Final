expression batdongsan_house = ```
	let
	    Source = Csv.Document(File.Contents(DatasetFolderPath & "\\segmented_by_type\\batdongsan_house.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
	    #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
	    #"Changed Type" = Table.TransformColumns(#"Promoted Headers", {
	        {"product_id", each let value = Text.Trim(Text.From(_)) in if value = "" then null else try Int64.From(Number.FromText(value)) otherwise null, Int64.Type},
	        {"price_total", each let value = Text.Trim(Text.From(_)) in if value = "" then null else try Number.FromText(value) otherwise null, type number},
	        {"price_per_m2", each let value = Text.Trim(Text.From(_)) in if value = "" then null else try Number.FromText(value) otherwise null, type number},
	        {"area", each let value = Text.Trim(Text.From(_)) in if value = "" then null else try Number.FromText(value) otherwise null, type number},
	        {"frontage", each let value = Text.Trim(Text.From(_)) in if value = "" then null else try Number.FromText(value) otherwise null, type number},
	        {"road_width", each let value = Text.Trim(Text.From(_)) in if value = "" then null else try Number.FromText(value) otherwise null, type number},
	        {"bedrooms", each let value = Text.Trim(Text.From(_)) in if value = "" then null else try Int64.From(Number.FromText(value)) otherwise null, Int64.Type},
	        {"bathrooms", each let value = Text.Trim(Text.From(_)) in if value = "" then null else try Int64.From(Number.FromText(value)) otherwise null, Int64.Type},
	        {"floors", each let value = Text.Trim(Text.From(_)) in if value = "" then null else try Int64.From(Number.FromText(value)) otherwise null, Int64.Type},
	        {"posted_date", each let value = Text.Trim(Text.From(_)) in if value = "" then null else try DateTime.FromText(value) otherwise null, type datetime},
	        {"expiry_date", each let value = Text.Trim(Text.From(_)) in if value = "" then null else try DateTime.FromText(value) otherwise null, type datetime}
	    })
	in
	    #"Changed Type" meta [IsParameterQuery=false, Type="Table"]