	column 'Tỷ lệ sâu/rộng' = ```
			
			DIVIDE(
			    'Fact_Listings'[Diện tích],
			    'Fact_Listings'[Mặt tiền] * 'Fact_Listings'[Mặt tiền] 
			)
			```
		lineageTag: 61fcde6b-8556-4f33-9ecf-2ecacd406db3
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Nhóm hình dáng thửa đất' =
			
			VAR TyLe =
			    DIVIDE(
			        'Fact_Listings'[Diện tích],
			        'Fact_Listings'[Mặt tiền] * 'Fact_Listings'[Mặt tiền]
			    )
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK('Fact_Listings'[Mặt tiền]) || ISBLANK('Fact_Listings'[Mặt tiền]), "Thiếu thông tin",
			        TyLe < 1.5, "Mặt tiền rộng",
			        TyLe < 3, "Cân đối",
			        TyLe < 5, "Nhà hẹp dài",
			        "Ống siêu dài"
			    )
		lineageTag: 945d6bae-2123-44bb-abc0-8f33c5c78492
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column PhanKhuc =
			
			// Bước 1: Tính các mốc bách phân vị dựa trên TOÀN BỘ dữ liệu và LÀM TRÒN
			VAR MocBinhDan = ROUND(CALCULATE(PERCENTILE.INC('Fact_Listings'[Khoảng giá], 0.25), ALL('Fact_Listings')), 0)
			VAR MocCaoCap = ROUND(CALCULATE(PERCENTILE.INC('Fact_Listings'[Khoảng giá], 0.75), ALL('Fact_Listings')), 0)
			
			// Bước 2: Phân loại
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK('Fact_Listings'[Khoảng giá]), "Không xác định",
			    'Fact_Listings'[Khoảng giá] <= MocBinhDan, "Bình dân",
			    'Fact_Listings'[Khoảng giá] <= MocCaoCap, "Trung bình",
			    "Cao cấp"
			)
		lineageTag: 90bfd98b-e4d0-4b17-9c66-b76cfa9322df
		summarizeBy: none
		sortByColumn: PhanKhuc_SapXep

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column PhanKhuc_SapXep =
			
			VAR MocBinhDan = CALCULATE(PERCENTILE.INC('Fact_Listings'[Khoảng giá], 0.25), ALL('Fact_Listings'))
			VAR MocCaoCap = CALCULATE(PERCENTILE.INC('Fact_Listings'[Khoảng giá], 0.75), ALL('Fact_Listings'))
			
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK('Fact_Listings'[Khoảng giá]), 4,
			    'Fact_Listings'[Khoảng giá] <= MocBinhDan, 1,
			    'Fact_Listings'[Khoảng giá] <= MocCaoCap, 2,
			    3
			)
		formatString: 0
		lineageTag: b3cdbcdc-aaf7-418b-b348-0f38e3ee5bd4

