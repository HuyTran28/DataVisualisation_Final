table Fact_Listings
	lineageTag: 6dbf4d8b-6450-49d9-a197-1bfe46312350

	measure 'Số tin đăng' = DISTINCTCOUNT('Fact_Listings'[Product_SKey])
		formatString: 0
		lineageTag: e15f350a-9647-4843-9040-c0148e055b39

	measure 'Điểm đỉnh' =
			
			VAR MaxSoTin =
			    MAXX(
			        ALLSELECTED('Fact_Listings'[Khoảng giá bán]),
			        [Số tin đăng]
			    )
			RETURN
			    IF([Số tin đăng] = MaxSoTin, [Số tin đăng], BLANK())
		formatString: 0
		lineageTag: d778376d-fec1-49f4-9d90-85d142246f83

	measure 'Vùng giá có nhiều tin nhất' =
			
			VAR BangTam =
			    ADDCOLUMNS(
			        ALLSELECTED('Fact_Listings'[Khoảng giá bán]),
			        "SoTin", [Số tin đăng]
			    )
			VAR DongCaoNhat =
			    TOPN(
			        1,
			        BangTam,
			        [SoTin],
			        DESC
			    )
			RETURN
			    CONCATENATEX(
			        DongCaoNhat,
			        'Fact_Listings'[Khoảng giá bán],
			        ", "
			    )
		lineageTag: c6fbed4a-a131-4bc4-bb3f-9784788ac6cb

	measure 'Ngưỡng rẻ bất thường' =
			
			PERCENTILEX.INC(
			    ALLSELECTED('Fact_Listings'),
			    'Fact_Listings'[Đơn giá],
			    0.05
			)
		lineageTag: 7b6faa7c-e6c9-4b17-a027-a3fa9dd305eb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Số tin rẻ bất thường' =
			
			CALCULATE(
			    [Số tin đăng],
			    FILTER(
			        ALLSELECTED('Fact_Listings'),
			        'Fact_Listings'[Đơn giá] <= [Ngưỡng rẻ bất thường]
			    )
			)
		formatString: 0
		lineageTag: 11001b22-e2f3-45fd-a729-108926e0bd92

	measure '% tin rẻ bất thường' =
			
			DIVIDE(
			    [Số tin rẻ bất thường],
			    [Số tin đăng]
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: d9812020-6fa3-4bd1-988d-c2fc42fc4fde

	measure '% Sổ hồng' =
			
			DIVIDE(
			    CALCULATE(COUNT('Fact_Listings'[Product_SKey]), 'Dim_Property_Details'[Pháp lý Chuẩn hóa] = "Sổ hồng/Sổ đỏ"),
			    COUNT('Fact_Listings'[Product_SKey]),
			    0
			)
		lineageTag: 78235c3e-e75f-4a2a-89ce-48af9b7832d1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Đơn giá TB Loại BĐS này' = CALCULATE(AVERAGE(Fact_Listings[Đơn giá]), ALLEXCEPT(Fact_Listings, Fact_Listings[Loại hình BĐS]))
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: ee9a8b3a-5683-405e-bdff-7cec040765d6

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

