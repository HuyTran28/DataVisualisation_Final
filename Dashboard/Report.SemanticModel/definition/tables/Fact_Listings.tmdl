		annotation GroupingDesignState = {"Version":0,"Sources":[{"Name":"f","Entity":"Fact_Listings"}],"GroupedColumns":[{"Column":{"Expression":{"SourceRef":{"Source":"f"}},"Property":"Đơn giá"}}],"BinItem":{"Expression":{"Floor":{"Expression":{"Column":{"Expression":{"SourceRef":{"Source":"f"}},"Property":"Đơn giá"}},"Size":2.0}}}}

		annotation SummarizationSetBy = Automatic

	column 'Diện tích (bins)' =
			IF(
				ISBLANK('Fact_Listings'[Diện tích]),
				BLANK(),
				IF(
					'Fact_Listings'[Diện tích] >= 0,
					ROUNDDOWN('Fact_Listings'[Diện tích] / 50, 0) * 50,
					ROUNDUP('Fact_Listings'[Diện tích] / 50, 0) * 50
				)
			)
		lineageTag: a4cfb452-2419-4475-b805-778ad83287fc
		summarizeBy: none

		extendedProperty GroupingMetadata =
