table Group2_ResidentialProperties
	lineageTag: a1b2c3d4-e5f6-47a8-b9c0-d1e2f3a4b5c6

	column Bedroom_Density = DIVIDE([bedrooms], [area])
		dataType: decimal
		formatString: 0.000
		lineageTag: 33333333-4444-5555-6666-7777777777777
		summarizeBy: average

		annotation SummarizationSetBy = Automatic

	column Is_Cramped = IF(AND([area] < 40, [bedrooms] >= 3), "Cramped", "Normal")
		dataType: string
		lineageTag: 44444444-5555-6666-7777-8888888888888
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Interior_Type = IF(SEARCH("Cơ bản", [interior], , 0) > 0 || SEARCH("Thô", [interior], , 0) > 0, "Bare/Basic", IF(SEARCH("Đầy đủ", [interior], , 0) > 0, "Full Furniture", "Other"))
		dataType: string
		lineageTag: 55555555-6666-7777-8888-9999999999999
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

