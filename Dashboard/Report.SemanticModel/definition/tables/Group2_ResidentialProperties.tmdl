	partition Group2_ResidentialProperties = m
		mode: import
		source =
				let
					ApartmentSource = Csv.Document(File.Contents(DatasetFolderPath & "\\segmented_by_type\\batdongsan_apartment.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
					ApartmentPromoted = Table.PromoteHeaders(ApartmentSource, [PromoteAllScalars=true]),
					HouseSource = Csv.Document(File.Contents(DatasetFolderPath & "\\segmented_by_type\\batdongsan_house.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
					HousePromoted = Table.PromoteHeaders(HouseSource, [PromoteAllScalars=true])
				in
					Table.Combine({ApartmentPromoted, HousePromoted})

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

